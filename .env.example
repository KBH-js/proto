# Proto OS - Environment Variables
# Copy this file to .env.local for local development overrides

# =============================================================================
# Remote Micro-Frontend URLs
# =============================================================================
# These URLs point to the deployed remote applications.
# In development, they default to localhost if not set.
# In production (Vercel), set these in the Vercel dashboard.

# Calculator Remote App
# Development default: http://localhost:5001/assets/remoteEntry.js
# Production example: https://your-calculator-remote.vercel.app/assets/remoteEntry.js
VITE_REMOTE_CALCULATOR_URL=

# =============================================================================
# Adding New Remotes
# =============================================================================
# When adding a new remote micro-frontend:
# 1. Deploy the remote to Vercel (or your hosting provider)
# 2. Add the environment variable here and in vite.config.ts
# 3. Set the production URL in Vercel dashboard
#
# Example:
# VITE_REMOTE_NOTES_URL=https://your-notes-remote.vercel.app/assets/remoteEntry.js
