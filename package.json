{
  "name": "proto",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "dev:remotes": "pnpm --parallel --filter \"@proto/remote-*\" dev",
    "build": "tsc -b && rsbuild build",
    "lint": "eslint .",
    "typecheck": "tsc -b && pnpm -r typecheck",
    "preview": "rsbuild preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:vrt": "playwright test --project=vrt",
    "test:vrt:update": "playwright test --project=vrt --update-snapshots"
  },
  "dependencies": {
    "@module-federation/enhanced": "^2.7.0",
    "@proto/shared": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-rnd": "^10.4.13",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@module-federation/rsbuild-plugin": "^2.7.0",
    "@playwright/test": "^1.61.1",
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-babel": "^2.0.1",
    "@rsbuild/plugin-react": "^2.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "happy-dom": "^15.11.7",
    "msw": "^2.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
